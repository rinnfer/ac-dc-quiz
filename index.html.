<!DOCTYPE html>
<html>
<head>
  <title>Hello lil bro - Personality Test</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      background: #111;
      color: white;
      padding: 40px;
    }
    .box {
      max-width: 500px;
      margin: auto;
      padding: 20px;
      background: #222;
      border-radius: 10px;
    }
    button {
      display: block;
      width: 100%;
      margin: 10px 0;
      padding: 10px;
      border: none;
      border-radius: 5px;
      background: #444;
      color: white;
      cursor: pointer;
    }
    button:hover {
      background: #666;
    }
    #progress {
      height: 10px;
      background: lime;
      width: 0%;
      margin-top: 20px;
    }
  </style>
</head>

<body>

<div class="box">
  <h1>Hello Arkan 👀</h1>
  <p id="question">Loading test...</p>
  <div id="answers"></div>
  <div id="progress"></div>
</div>

<script>
let questions = [
  {
    q: "What do you do in your free time?",
    a: ["turning ur freind image into femboy", "stalking", "Scroll TikTok", "Think about imam"]
  },
  {
    q: "Pick a color:",
    a: ["Black", "Blue", "green😳", "Red"]
  },
  {
    q: "Your vibe is:",
    a: ["Shy dwarf", "lil bro", "Acoistic", "Mysterious alpha wolf"]
  },
  {
    q: "Favorite activity:",
    a: ["cuddle with ili", "Gaming In femboy obby", "Listening to Femboy asmr", "Doing femboy thing"]
  }
];

let current = 0;

function showQuestion() {
  document.getElementById("question").innerText = questions[current].q;
  let answersHTML = "";

  questions[current].a.forEach(ans => {
    answersHTML += `<button onclick="next()">${ans}</button>`;
  });

  document.getElementById("answers").innerHTML = answersHTML;
  document.getElementById("progress").style.width = ((current / questions.length) * 100) + "%";
}

function next() {
  current++;

  if (current < questions.length) {
    showQuestion();
  } else {
    loadingScreen();
  }
}

function loadingScreen() {
  document.getElementById("question").innerText = "Analyzing results...";
  document.getElementById("answers").innerHTML = "";
  
  let width = 0;
  let bar = document.getElementById("progress");

  let interval = setInterval(() => {
    width++;
    bar.style.width = width + "%";

    if (width >= 100) {
      clearInterval(interval);
      reveal();
    }
  }, 30);
}

function reveal() {
  document.body.innerHTML = `
    <h1>FINAL RESULT</h1>
    <h2>100% FEMBOY 😭</h2>
    <p>Analysis complete. No escape.</p>
  `;

  // Rickroll redirect after 2.5 seconds
  setTimeout(() => {
    window.location.href = "https://www.youtube.com/watch?v=dQw4w9WgXcQ";
  }, 2500);
}

showQuestion();
</script>

</body>
</html>>
